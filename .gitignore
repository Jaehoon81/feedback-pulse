# ─────────────────────────────────────────────────────────────
# dependencies
# ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.*

# ─────────────────────────────────────────────────────────────
# Next.js
# ─────────────────────────────────────────────────────────────
.next/
out/
build/
next-env.d.ts
*.tsbuildinfo

# ─────────────────────────────────────────────────────────────
# environment variables (서버 전용 시크릿)
# .env.example만 git에 커밋되고 나머지는 모두 ignore
# ─────────────────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.production.local
.env.*.local
!.env.example

# ─────────────────────────────────────────────────────────────
# vercel
# ─────────────────────────────────────────────────────────────
.vercel/

# ─────────────────────────────────────────────────────────────
# testing
# ─────────────────────────────────────────────────────────────
coverage/
playwright-report/
test-results/
.artifacts/*
!.artifacts/.gitkeep
.playwright-mcp/

# ─────────────────────────────────────────────────────────────
# python (하네스 scripts/)
# ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# ─────────────────────────────────────────────────────────────
# logs
# ─────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─────────────────────────────────────────────────────────────
# OS files
# ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─────────────────────────────────────────────────────────────
# editors
# ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─────────────────────────────────────────────────────────────
# harness phase execution outputs (코드 명세는 git에, 실행 산출물만 ignore)
# ─────────────────────────────────────────────────────────────
phases/**/phase*-output.json
phases/**/step*-output.json
